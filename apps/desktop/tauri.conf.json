{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Camtu",
  "version": "0.0.1",
  "identifier": "com.camtu.app",
  "build": {
    "beforeDevCommand": "npm --prefix ./apps/web run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm --prefix ./apps/web run build",
    "frontendDist": "../web/dist"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/keira-editor/keira4/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCNzEzRUJBRTM1NjE2MzcKUldRM0ZsYmp1ajV4MnlYMXRWSWx2ekQvOFhNeS92VVFhMkhHZFp2Z1Y2anlZK0hxc0hRQ1pwWVcK"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Camtu",
        "decorations": false,
        "transparent": true,
        "minWidth": 800,
        "minHeight": 600,
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "publisher": "Camtu Inc",
    "category": "Utilities",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    },
    "createUpdaterArtifacts": true
  }
}
