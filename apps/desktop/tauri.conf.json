{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "camtu-desktop",
  "version": "0.1.0",
  "identifier": "com.camtu.app",
  "build": {
    "beforeDevCommand": "npm --prefix ./apps/web run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm --prefix ./apps/web run build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "camtu-desktop",
        "decorations": false,
        "transparent": true,
        "minWidth": 800,
        "minHeight": 600,
        "width": 1600,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
