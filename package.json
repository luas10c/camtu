{
  "name": "camtu",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev:desktop": "tauri dev --config apps/desktop/tauri.conf.json",
    "build:desktop": "tauri build --config apps/desktop/tauri.conf.json",
    "dev:web": "npm run dev -w web",
    "build:web": "npm run build -w web",
    "lint:web": "npm run lint -w web",
    "start:mobile": "npm run start -w mobile",
    "android:mobile": "npm run android -w mobile",
    "build-android": "npm run build-android -w mobile",
    "ios:mobile": "npm run ios -w mobile",
    "build-ios:mobile": "npm run build-ios -w mobile",
    "lint:mobile": "npm run lint -w mobile"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "license": "MIT"
}
